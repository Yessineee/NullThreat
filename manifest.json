{
  "manifest_version": 3,
  "name": "NullThreat",
  "version": "1.0.0",
  "description": "Scan PDF downloads with VirusTotal",
  "permissions": ["downloads", "storage", "notifications", "alarms", "tabs"],
  "host_permissions": ["https://www.virustotal.com/*"],
  "background": {
    "service_worker": "src/background/worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": "icons/icon48.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/dashboard/dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}